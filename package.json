{
  "name": "lottery-system",
  "private": true,
  "version": "1.0.0",
  "description": "六合彩特码预测系统 - 基于AI和统计分析的智能预测工具",
  "author": "Lottery System Team",
  "main": "electron.cjs",
  "workspaces": [
    "backend"
  ],
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "npm run dev --workspace=backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "vite build",
    "build:backend": "npm run build --workspace=backend",
    "build": "npm run build:frontend && npm run build:backend",
    "preview": "vite preview",
    "build:app": "npm run build:frontend && npm run package:app",
    "package:app": "electron-builder --config electron-builder.json",
    "electron:dev": "concurrently \"npm run dev:frontend\" \"electron .\"",
    "electron:build": "npm run build:backend && npm run build:frontend && electron-builder --config electron-builder.json"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "^0.577.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "concurrently": "^9.2.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "6.3.5",
    "electron-builder": "^25.0.0",
    "vite-plugin-singlefile": "2.3.0",
    "electron": "^33.0.0"
  }
}
